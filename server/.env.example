# Server Environment Variables
# Copy this file to server/.env — NEVER commit server/.env to the repository

# Required: Secret key for signing JWT access tokens
# Generate a strong secret: openssl rand -hex 64
JWT_SECRET=

# Required: ContentPaywall contract address on Rootstock Testnet
CONTENT_PAYWALL_ADDRESS=0xb5C7ED1CEd1098974FDf2a9060948F13138e9dC6

# Optional: Rootstock Testnet RPC URL (defaults to public node)
RSK_RPC_URL=https://public-node.testnet.rsk.co

# Optional: Port the Express server listens on (default: 3001)
PORT=3001

# Optional: Comma-separated list of allowed frontend origins for CORS
# (default: http://localhost:5173)
CORS_ORIGINS=http://localhost:5173

# Production: set to 1 when the app runs behind a reverse proxy so rate limits use X-Forwarded-For
# TRUST_PROXY=1
