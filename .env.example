# Privy project ID (required)
VITE_PRIVY_APP_ID=

# ContentPaywall contract address on Rootstock Testnet (required)
# L4: Moved from hardcoded constants to env-based configuration
VITE_CONTENT_PAYWALL_ADDRESS=0xb5C7ED1CEd1098974FDf2a9060948F13138e9dC6

# Backend API URL (defaults to http://localhost:3001 if not set)
VITE_API_URL=http://localhost:3001

# Etherspot bundler (for Account Abstraction demo)
VITE_BUNDLER_API_KEY='etherspot_public_key'
VITE_CUSTOM_BUNDLER_URL=https://rootstocktestnet-bundler.etherspot.io/

# ─── Server-side only (server/.env) ──────────────────────────────────────────
# These are NOT prefixed with VITE_ and must NOT be in the frontend .env.
# Create a separate server/.env file with the following:
#
# JWT_SECRET=<generate with: openssl rand -hex 64>
# CONTENT_PAYWALL_ADDRESS=0xb5C7ED1CEd1098974FDf2a9060948F13138e9dC6
# RSK_RPC_URL=https://public-node.testnet.rsk.co
# PORT=3001
# CORS_ORIGINS=http://localhost:5173
